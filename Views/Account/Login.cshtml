@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="auth-container">
    <div class="auth-card">
        <div style="text-align:center;margin-bottom:36px;">
            <div style="width:64px;height:64px;background:linear-gradient(135deg,#6C63FF,#43CBFF);border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 20px;">✦</div>
            <h1 class="auth-title">Welcome back</h1>
            <p class="auth-subtitle">Sign in to your TaskFlow account</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary(true)
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="form-group">
                <label class="form-label" asp-for="Email">Email address</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Password">Password</label>
                <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password"></span>
            </div>

            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;">
                <label style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--text-secondary);cursor:pointer;">
                    <input asp-for="RememberMe" type="checkbox" style="accent-color:var(--accent);" />
                    Remember me
                </label>
            </div>

            <button type="submit" class="btn btn-primary">Sign In →</button>
        </form>

        <div class="divider">or</div>

        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:14px 18px;font-size:13px;color:var(--text-secondary);">
            <strong style="color:white;">Demo accounts:</strong><br/>
            👤 demo@todoapp.com / Demo@123456<br/>
            🔑 admin@todoapp.com / Admin@123456
        </div>

        <div class="auth-link">
            Don't have an account? <a asp-action="Register">Create one →</a>
        </div>
    </div>
</div>
