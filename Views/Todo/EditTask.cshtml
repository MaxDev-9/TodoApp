@model CreateTaskViewModel
@{
    ViewData["Title"] = "Edit Task";
}

<div class="main-container" style="max-width:600px;">
    <a asp-action="ListDetail" asp-route-id="@Model.TodoListId" class="back-link">← Back to List</a>

    <div class="glass fade-in" style="padding:40px;">
        <h1 class="page-title" style="margin-bottom:8px;font-size:26px;">Edit Task</h1>
        <p class="page-subtitle" style="margin-bottom:32px;">Update task details</p>

        <form asp-action="EditTask" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TodoListId" />

            <div class="form-group">
                <label class="form-label" asp-for="Title">Task Title *</label>
                <input asp-for="Title" class="form-control" autofocus />
                <span asp-validation-for="Title"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Description">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" style="resize:none;"></textarea>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label" asp-for="DueDate">Due Date</label>
                    <input asp-for="DueDate" class="form-control" type="datetime-local" />
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Priority">Priority</label>
                    <select asp-for="Priority" class="form-control">
                        <option value="0">🟢 Low</option>
                        <option value="1">🟡 Medium</option>
                        <option value="2">🔴 High</option>
                        <option value="3">🚨 Urgent</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Notes">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3" style="resize:none;"></textarea>
            </div>

            <div style="display:flex;gap:12px;margin-top:32px;">
                <button type="submit" class="btn btn-primary" style="flex:1;">Save Changes</button>
                <a asp-action="ListDetail" asp-route-id="@Model.TodoListId" class="btn btn-glass" style="flex:0 0 auto;">Cancel</a>
            </div>
        </form>
    </div>
</div>
