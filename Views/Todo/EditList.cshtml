@model CreateTodoListViewModel
@{
    ViewData["Title"] = "Edit List";
}

<div class="main-container" style="max-width:600px;">
    <a asp-action="Index" class="back-link">← Back to Lists</a>

    <div class="glass fade-in" style="padding:40px;">
        <h1 class="page-title" style="margin-bottom:8px;font-size:26px;">Edit List</h1>
        <p class="page-subtitle" style="margin-bottom:32px;">Update list details</p>

        <form asp-action="EditList" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label" asp-for="Title">List Title *</label>
                <input asp-for="Title" class="form-control" autofocus />
                <span asp-validation-for="Title"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Description">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" style="resize:none;"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="DueDate">Due Date</label>
                <input asp-for="DueDate" class="form-control" type="datetime-local" />
            </div>

            <div class="form-group">
                <label class="form-label">Color</label>
                <div class="color-picker-row" id="colorPicker">
                    @foreach (var color in new[] { "#6C63FF","#FF6584","#43CBFF","#4ECB8D","#FFB74D","#FF5252","#E040FB","#F06292" })
                    {
                        <div class="color-swatch @(Model.Color == color ? "selected" : "")"
                             style="background:@color;"
                             onclick="selectColor('@color')" title="@color"></div>
                    }
                </div>
                <input asp-for="Color" type="hidden" id="colorInput" />
            </div>

            <div style="display:flex;gap:12px;margin-top:32px;">
                <button type="submit" class="btn btn-primary" style="flex:1;">Save Changes</button>
                <a asp-action="Index" class="btn btn-glass" style="flex:0 0 auto;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function selectColor(color) {
    document.getElementById('colorInput').value = color;
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
    event.target.classList.add('selected');
}
</script>
}
